{
  "name": "@ckeditor/ckeditor5-inspector",
  "main": "build/inspector.js",
  "files": [
    "build",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md"
  ],
  "description": "The official CKEditor 5 instance inspector.",
  "license": "SEE LICENSE IN LICENSE.md",
  "version": "5.0.0",
  "engines": {
    "node": ">=24.11.0",
    "pnpm": ">=10.28.0",
    "yarn": "\n\n┌─────────────────────────┐\n│  Hey, we use pnpm now!  │\n└─────────────────────────┘\n\n"
  },
  "scripts": {
    "nice": "ckeditor5-dev-changelog-create-entry",
    "postinstall": "node ./scripts/postinstall.mjs",
    "serve": "node ./scripts/serve.mjs",
    "build": "rimraf -g './build/*' && concurrently --group 'pnpm:build:inspector' 'pnpm:build:mini'",
    "build:inspector": "vite build --mode production -- --variant=inspector",
    "build:mini": "vite build --mode production -- --variant=mini",
    "dev": "concurrently -c 'blue,' --kill-others 'pnpm:serve' 'pnpm:watch:inspector' 'pnpm:watch:mini'",
    "watch:inspector": "vite build --watch --mode production -- --variant=inspector",
    "watch:mini": "vite build --watch --mode production -- --variant=mini",
    "release:prepare-changelog": "node ./scripts/preparechangelog.mjs",
    "release:prepare-packages": "node ./scripts/preparepackages.mjs",
    "release:publish-packages": "node ./scripts/publishpackages.mjs",
    "test": "vitest --config ./vite.config.mjs --run",
    "test:scripts": "vitest --config ./scripts-tests/vitest.config.mjs --run",
    "lint": "eslint",
    "validate-license-files": "node ./scripts/ci/validate-license-files.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ckeditor/ckeditor5-inspector.git"
  },
  "author": "CKSource (http://cksource.com/)",
  "bugs": {
    "url": "https://github.com/ckeditor/ckeditor5-inspector/issues"
  },
  "homepage": "https://github.com/ckeditor/ckeditor5-inspector",
  "dependencies": {
    "copy-to-clipboard": "^3.3.1",
    "es-toolkit": "^1.44.0",
    "javascript-stringify": "^2.1.0",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "react-modal": "^3.14.4",
    "react-redux": "^7.2.6",
    "react-rnd": "~10.2.4",
    "redux": "^4.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.16.0",
    "@babel/preset-react": "^7.16.0",
    "@ckeditor/ckeditor5-dev-bump-year": "^54.3.4",
    "@ckeditor/ckeditor5-dev-changelog": "^54.3.4",
    "@ckeditor/ckeditor5-dev-ci": "^54.3.4",
    "@ckeditor/ckeditor5-dev-license-checker": "^54.3.4",
    "@ckeditor/ckeditor5-dev-release-tools": "^54.3.4",
    "@ckeditor/ckeditor5-dev-utils": "^54.3.4",
    "@inquirer/prompts": "^7.8.3",
    "@listr2/prompt-adapter-inquirer": "^3.0.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^12.1.5",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "ckeditor5": "^47.6.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.34.0",
    "eslint-config-ckeditor5": "^13.0.0",
    "eslint-plugin-ckeditor5-rules": "^13.0.0",
    "eslint-plugin-react": "^7.37.5",
    "fs-extra": "^11.3.0",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "lightningcss": "^1.31.1",
    "lint-staged": "^10.5.4",
    "listr2": "^9.0.2",
    "minimist": "^1.2.8",
    "playwright": "^1.55.0",
    "rimraf": "^6.1.3",
    "serve": "^14.2.6",
    "typescript": "^5.0.0",
    "upath": "^2.0.1",
    "vite": "^7.0.0",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vite-plugin-svgr": "^4.4.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "**/*": [
      "eslint --quiet"
    ]
  }
}
